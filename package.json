  ],
  "browser": {
    "fs": false,
    "path": false,
    "os": false,
    "stream": false,
    "fs-extra": false,
    "ora": false,
    "chalk": false,
    "commander": false
  },
  "publishConfig": {
    "access": "public"
  }
}
